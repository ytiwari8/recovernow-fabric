table Transactions
	lineageTag: 3a9e9783-6c85-4751-91d1-180cfbf179e1

	/// Net collections: sum of revenue transaction amounts (credits positive, debits negative).
	measure 'Net Collections' =
			CALCULATE(
			    SUM('Transactions'[amount]),
			    KEEPFILTERS('Transactions'[Cleaned Type] = "Revenue")
			)
		formatString: $#,##0;($#,##0)
		displayFolder: KPIs
		lineageTag: 05e32f69-ea14-4982-bf3f-5de17ce33d49

	/// Net collections for VA transactions only (description contains 'VA').
	measure 'Net Collections - VA' =
			CALCULATE(
			    SUM('Transactions'[amount]),
			    KEEPFILTERS('Transactions'[Cleaned Type] = "Revenue"),
			    'Transactions'[va_flag] = "VA"
			)
		formatString: $#,##0;($#,##0)
		displayFolder: KPIs
		lineageTag: 048cf131-bca5-4ed3-a242-63e229379ea0

	/// Trailing 4-week net collections: sums Revenue amounts for the 4 weeks ending on the current week_ending in context.
	measure 'Net Collections T4W' =
			VAR _WeekEnd = SELECTEDVALUE('Transactions'[Week Ending])
			VAR _4WeeksAgo = _WeekEnd - 27
			RETURN
			    IF(
			        NOT ISBLANK(_WeekEnd),
			        CALCULATE(
			            SUM('Transactions'[amount]),
			            KEEPFILTERS('Transactions'[Cleaned Type] = "Revenue"),
			            'Transactions'[Week Ending] >= _4WeeksAgo,
			            'Transactions'[Week Ending] <= _WeekEnd,
			            ALL('Transactions'[Week Ending])
			        ),
			        CALCULATE(
			            SUM('Transactions'[amount]),
			            KEEPFILTERS('Transactions'[Cleaned Type] = "Revenue")
			        )
			    )
		formatString: $#,##0;($#,##0)
		displayFolder: KPIs
		lineageTag: d4c7f266-e908-4e70-83ca-4c98bc61bdb7

	/// Net collections for Non-VA transactions only (description does not contain 'VA').
	measure 'Net Collections - Non-VA' =
			CALCULATE(
			    SUM('Transactions'[amount]),
			    KEEPFILTERS('Transactions'[Cleaned Type] = "Revenue"),
			    'Transactions'[va_flag] = "Non-VA"
			)
		formatString: $#,##0;($#,##0)
		displayFolder: KPIs
		lineageTag: c02e3dd8-c573-4e3e-ad62-f394d19ef25c

	/// Weekly net cash flow: sum of all transaction amounts regardless of type — revenue, expenses, salaries, transfers in/out. Represents the true net change in cash for the week.
	measure 'Net Cash Flow' = SUM('Transactions'[amount])
		formatString: $#,##0;($#,##0)
		displayFolder: KPIs
		lineageTag: 6cac1d4d-f7a0-4152-a71c-0d698f969683

	/// Trailing 4-week net cash flow: rolling sum of all transaction amounts across the 4 weeks ending on the current Week Ending in context.
	measure 'Net Cash Flow T4W' =
			VAR _WeekEnd = SELECTEDVALUE('Transactions'[Week Ending])
			VAR _4WeeksAgo = _WeekEnd - 27
			RETURN
			    IF(
			        NOT ISBLANK(_WeekEnd),
			        CALCULATE(
			            SUM('Transactions'[amount]),
			            'Transactions'[Week Ending] >= _4WeeksAgo,
			            'Transactions'[Week Ending] <= _WeekEnd,
			            ALL('Transactions'[Week Ending])
			        ),
			        SUM('Transactions'[amount])
			    )
		formatString: $#,##0;($#,##0)
		displayFolder: KPIs
		lineageTag: eb83951b-6da3-4022-b0dd-1a3a277dc70b

	/// Returns the most recent Week Ending date in transactions as a formatted string for display in a card visual.
	measure 'Report As Of - Cash' = FORMAT(MAX('Transactions'[Week Ending]), "M/D/YY")
		formatString: @
		displayFolder: KPIs
		lineageTag: d5c37a91-9dd8-423f-8746-ca22324ecb79


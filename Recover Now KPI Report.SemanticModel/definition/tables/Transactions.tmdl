	/// Flags transactions as VA if description contains 'VA', otherwise Non-VA.
	column va_flag = IF(SEARCH("VA", 'Transactions'[description], 1, 0) > 0, "VA", "Non-VA")
		dataType: string
		displayFolder: Dimensions
		lineageTag: cbe095b5-41f6-401c-8ab0-993212854476
		summarizeBy: none

	/// Facility-level code joining to dim_entity. Maps bank entity+account combination to a single facility code: Widespread accounts disaggregate to TER/Lotus/GAW/GLR/CRC; Recover Now Georgia/Alabama become RNGA/RNAL; Longbranch and EDTC pass through.
	column facility_code =
			SWITCH(
			    TRUE(),
			    'Transactions'[entity] = "Longbranch", "Longbranch",
			    'Transactions'[entity] = "EDTC", "EDTC",
			    'Transactions'[entity] = "Recover Now Georgia", "RNGA",
			    'Transactions'[entity] = "Recover Now Alabama", "RNAL",
			    'Transactions'[entity] = "Widespread" && 'Transactions'[account] = "Tides Edge Recovery", "TER",
			    'Transactions'[entity] = "Widespread" && 'Transactions'[account] = "LOTUS WELLNESS", "Lotus",
			    'Transactions'[entity] = "Widespread" && 'Transactions'[account] = "GREEN ACRES", "GAW",
			    'Transactions'[entity] = "Widespread" && 'Transactions'[account] = "new grace land", "GLR",
			    'Transactions'[entity] = "Widespread" && 'Transactions'[account] = "chattanooga", "CRC",
			    BLANK()
			)
		dataType: string
		displayFolder: Dimensions
		lineageTag: dfe8bf88-0d85-447f-8212-a0a7a30cd466
		summarizeBy: none

	/// Last day of the month the transaction occurred in. Used to align bank transactions to monthly grain for joining with budget and historical tables.
	column month_ending = EOMONTH('Transactions'[date], 0)
		dataType: dateTime
		formatString: yyyy-mm-dd
		displayFolder: Dimensions
		lineageTag: 1a96541f-fa8a-472b-abc3-5f368363ec63
		summarizeBy: none


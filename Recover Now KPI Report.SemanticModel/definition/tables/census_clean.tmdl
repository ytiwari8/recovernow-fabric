	/// Latest 2026 month with census data. Used as the YTD cutoff for all YTD measures.
	measure 'YTD Cutoff Month' = CALCULATE(MAX('census_clean'[month]), 'census_clean'[month] >= "2026-01")
		formatString: @
		displayFolder: YTD
		lineageTag: 4f4bfb21-cd76-49bf-b378-774b89cac9a4

	/// YTD average budget ADC for EDTC. Averages monthly budget from 2026-01 through latest actual month.
	measure 'YTD Budget - EDTC' =
			VAR _Cutoff = [YTD Cutoff Month]
			VAR _MonthCount = CALCULATE(COUNTROWS('budget'), 'budget'[budget_category] = "EDTC", 'budget'[month] >= "2026-01", 'budget'[month] <= _Cutoff)
			RETURN DIVIDE(
			    CALCULATE(SUM('budget'[budget_adc]), 'budget'[budget_category] = "EDTC", 'budget'[month] >= "2026-01", 'budget'[month] <= _Cutoff),
			    _MonthCount
			)
		formatString: #,##0.0
		displayFolder: YTD
		lineageTag: a8f6c481-1c7e-40ba-bba8-07dde0166389

	/// YTD average budget ADC for VA Abita.
	measure 'YTD Budget - VA Abita' =
			VAR _Cutoff = [YTD Cutoff Month]
			VAR _MonthCount = CALCULATE(COUNTROWS('budget'), 'budget'[budget_category] = "VA Abita", 'budget'[month] >= "2026-01", 'budget'[month] <= _Cutoff)
			RETURN DIVIDE(
			    CALCULATE(SUM('budget'[budget_adc]), 'budget'[budget_category] = "VA Abita", 'budget'[month] >= "2026-01", 'budget'[month] <= _Cutoff),
			    _MonthCount
			)
		formatString: #,##0.0
		displayFolder: YTD
		lineageTag: 743654d6-f7e5-457d-8c1c-34d5b8b31399

	/// YTD average budget ADC for Other Abita.
	measure 'YTD Budget - Other Abita' =
			VAR _Cutoff = [YTD Cutoff Month]
			VAR _MonthCount = CALCULATE(COUNTROWS('budget'), 'budget'[budget_category] = "Other Abita", 'budget'[month] >= "2026-01", 'budget'[month] <= _Cutoff)
			RETURN DIVIDE(
			    CALCULATE(SUM('budget'[budget_adc]), 'budget'[budget_category] = "Other Abita", 'budget'[month] >= "2026-01", 'budget'[month] <= _Cutoff),
			    _MonthCount
			)
		formatString: #,##0.0
		displayFolder: YTD
		lineageTag: f5e1bec8-ad16-497b-b241-b2003cfbfe94

	/// YTD average budget ADC for Abita Total (VA Abita + Other Abita).
	measure 'YTD Budget - Abita Total' =
			VAR _Cutoff = [YTD Cutoff Month]
			VAR _MonthCount = CALCULATE(DISTINCTCOUNT('budget'[month]), 'budget'[budget_category] IN {"VA Abita", "Other Abita"}, 'budget'[month] >= "2026-01", 'budget'[month] <= _Cutoff)
			VAR _TotalBudget = CALCULATE(SUM('budget'[budget_adc]), 'budget'[budget_category] IN {"VA Abita", "Other Abita"}, 'budget'[month] >= "2026-01", 'budget'[month] <= _Cutoff)
			RETURN DIVIDE(_TotalBudget, _MonthCount)
		formatString: #,##0.0
		displayFolder: YTD
		lineageTag: 6029102d-6034-40d7-a2f1-01a0a4776a27

	/// YTD average budget ADC for NORA.
	measure 'YTD Budget - NORA' =

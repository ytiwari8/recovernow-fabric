		lineageTag: d8fb307b-786b-4d21-9af0-55eeb3c55176

	/// YTD Variance ADC for Lotus.
	measure 'YTD Variance - Lotus' = [YTD Actual - Lotus] - [YTD Budget - Lotus]
		formatString: #,##0.0;-#,##0.0
		displayFolder: YTD
		lineageTag: 2c82f795-de1a-4553-a09c-ee4a94bee45b


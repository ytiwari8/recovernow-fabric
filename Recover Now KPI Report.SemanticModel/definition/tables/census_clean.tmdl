	/// Consolidated program group: Detox + Residential = Inpatient, Female NORA merged into NORA, all others unchanged.
	column program_group_consolidated =
			SWITCH(
			    'census_clean'[program_group],
			    "Detox",        "Inpatient",
			    "Residential",  "Inpatient",
			    "Female NORA",  "NORA",
			    'census_clean'[program_group]
			)
		dataType: string
		displayFolder: Dimensions
		lineageTag: 20f99cbe-e8e0-4e30-9e40-bcbdf5bc85ad
		summarizeBy: none
		sortByColumn: program_group_sort_order

	/// Sort order for program_group_consolidated. Used to drive custom sort in visuals.
	column program_group_sort_order =
			SWITCH(
			    'census_clean'[program_group],
			    "Detox",        1,
			    "Residential",  1,
			    "Female NORA",  2,
			    "NORA",         2,
			    "IOP",          3,
			    "PHP",          4,
			    "OP",           5,
			    "Other",        6,
			    7
			)
		dataType: int64
		isHidden
		displayFolder: Dimensions
		lineageTag: c4fb7538-fa83-4be4-a071-f686441e5543
		summarizeBy: none


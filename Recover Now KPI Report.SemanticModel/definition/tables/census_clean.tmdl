		lineageTag: e8c13df6-3733-4493-b132-5d951df177a0

	/// Peak 2026 budgeted ADC for EDTC. Highest single month budget value across all 2026 months.
	measure 'Peak Budget - EDTC' = 17
		formatString: #,##0.0
		displayFolder: YTD
		lineageTag: adbb60a4-6586-48f3-b226-8d8e2f4078f4

	/// Peak 2026 budgeted ADC for VA Abita.
	measure 'Peak Budget - VA Abita' = CALCULATE(MAX('budget'[budget_adc]), 'budget'[budget_category] = "VA Abita", 'budget'[month] >= "2026-01")
		formatString: #,##0.0
		displayFolder: YTD
		lineageTag: f61aa618-4d6e-4806-9528-ea983c630f1a

	/// Peak 2026 budgeted ADC for Other Abita.
	measure 'Peak Budget - Other Abita' = CALCULATE(MAX('budget'[budget_adc]), 'budget'[budget_category] = "Other Abita", 'budget'[month] >= "2026-01")
		formatString: #,##0.0
		displayFolder: YTD
		lineageTag: 73332b21-108f-49fe-9db8-10334dc3a2db

	/// Peak 2026 budgeted ADC for Abita Total. Finds the month with highest combined VA Abita + Other Abita budget.
	measure 'Peak Budget - Abita Total' = 58
		formatString: #,##0.0
		displayFolder: YTD
		lineageTag: 42dc8134-3c9a-48fb-b9f2-de8f1b2ac0bc

	/// Peak 2026 budgeted ADC for NORA. Set to 24.
	measure 'Peak Budget - NORA' = 27
		formatString: #,##0.0
		displayFolder: YTD
		lineageTag: e4383615-b6ed-4571-928d-eb02fd044252

	/// Peak 2026 budgeted ADC for RNGA.
	measure 'Peak Budget - RNGA' = 24
		formatString: #,##0.0
		displayFolder: YTD
		lineageTag: 29e984b5-1a05-448d-b458-76ce8eec7cf4

	/// Peak 2026 budgeted ADC for RNAL.
	measure 'Peak Budget - RNAL' = 25
		formatString: #,##0.0
		displayFolder: YTD
		lineageTag: b9cd2756-9f83-4316-ae9a-623bc8e9cc40

	/// Peak 2026 budgeted ADC for Lotus. Flat rate of 18.
	measure 'Peak Budget - Lotus' = 22
		formatString: #,##0.0
		displayFolder: YTD
		lineageTag: 9166da3c-d3e7-4a08-a511-643f97e0ade9

	/// Peak 2026 budgeted ADC for Green Acres. Flat rate of 21.
	measure 'Peak Budget - Green Acres' = 26
		formatString: #,##0.0
		displayFolder: YTD
		lineageTag: 34b2637d-57b5-4673-967d-f1e7941f610d

	/// Peak 2026 budgeted ADC for Tides. Flat rate of 32.
	measure 'Peak Budget - Tides' = 38
		formatString: #,##0.0
		displayFolder: YTD
		lineageTag: 915687a7-cb20-43ec-8efe-4fe296e3120e

	/// Peak 2026 budgeted ADC for CRC. Flat rate of 28.
	measure 'Peak Budget - CRC' = 28
		formatString: #,##0.0
		displayFolder: YTD
		lineageTag: dee81ab5-b648-4e27-b324-3c723c0825b5

	/// Peak 2026 budgeted ADC for Graceland. Flat rate of 28.
	measure 'Peak Budget - Graceland' = 28
		formatString: #,##0.0
		displayFolder: YTD
		lineageTag: 366ede56-a883-43a3-92bb-dd5aa999c8d3

	measure 'Util % - RNAL' =
			VAR _ADC =
			    CALCULATE(
			        [ADC],
			        'census_clean'[facility] = "RNAL"
			    )
			RETURN
			    DIVIDE(_ADC, 25)
		lineageTag: 7099ed6b-be3c-4694-a548-149325fe9fdd


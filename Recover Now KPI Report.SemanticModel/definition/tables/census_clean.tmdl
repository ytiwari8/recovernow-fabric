		displayFolder: YTD
		lineageTag: c64aa76b-c878-4acc-8a81-ab32a340f3b3

	/// YTD Variance % for EDTC.
	measure 'YTD Variance % - EDTC' = DIVIDE([YTD Actual - EDTC] - [YTD Budget - EDTC], [YTD Budget - EDTC])
		formatString: +0.0%;-0.0%
		displayFolder: YTD
		lineageTag: 316be9ce-2dc0-4090-a660-0043929fc3de

	/// YTD Variance % for VA Abita.
	measure 'YTD Variance % - VA Abita' = DIVIDE([YTD Actual - VA Abita] - [YTD Budget - VA Abita], [YTD Budget - VA Abita])
		formatString: +0.0%;-0.0%
		displayFolder: YTD
		lineageTag: aa5c7ac7-64dc-48d6-916c-69b26f04d180

	/// YTD Variance % for Abita Total.
	measure 'YTD Variance % - Abita Total' = DIVIDE([YTD Actual - Abita Total] - [YTD Budget - Abita Total], [YTD Budget - Abita Total])
		formatString: +0.0%;-0.0%
		displayFolder: YTD
		lineageTag: f8c93221-bff4-4eed-a788-7937d7eebc09

	/// YTD Variance % for NORA.

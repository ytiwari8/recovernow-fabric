table census_clean
	lineageTag: 178f3241-3078-4abb-b8ba-805f7760a456

	/// Average Daily Census. Weekly ADC = patient-days / distinct census dates, with the denominator held at the week/facility grain so the measure stays additive when split by payor, program, or other per-patient attributes (segments sum to the facility total). Absent weeks count as 0 so every segment averages over the same week set. At multi-week grain, averages the per-week ADC. Facility/location totals are identical to the prior definition.
	measure ADC =
			VAR _WeekTable =
			    CALCULATETABLE(
			        VALUES('census_clean'[week_ending]),
			        ALLEXCEPT(
			            'census_clean',
			            'census_clean'[month],
			            'census_clean'[year],
			            'census_clean'[census_date],
			            'census_clean'[week_ending],
			            'census_clean'[facility],
			            'census_clean'[location_name],
			            'census_clean'[location_id]
			        )
			    )
			RETURN
			    AVERAGEX(
			        _WeekTable,
			        VAR _wk = 'census_clean'[week_ending]
			        VAR _num =
			            COALESCE(
			                CALCULATE(COUNTROWS('census_clean'), 'census_clean'[week_ending] = _wk),
			                0
			            )
			        VAR _den =
			            CALCULATE(
			                DISTINCTCOUNT('census_clean'[census_date]),
			                ALLEXCEPT(
			                    'census_clean',
			                    'census_clean'[month],
			                    'census_clean'[year],
			                    'census_clean'[census_date],
			                    'census_clean'[facility],
			                    'census_clean'[location_name],
			                    'census_clean'[location_id]
			                ),
			                'census_clean'[week_ending] = _wk
			            )
			        RETURN DIVIDE(_num, _den)
			    )
		formatString: #,##0.0
		displayFolder: KPIs
		lineageTag: fbcc6de2-9eed-4cb9-a34b-0b715b024a75

	/// Utilization for Longbranch Eating Disorder Treatment Center. ADC / 17 licensed beds.
	measure 'Util % - Longbranch Eating Disorder' =
			VAR _ADC =
			    CALCULATE(
			        [ADC],
			        'census_clean'[location_name] = "Eating Disorder Treatment Center"
			    )
			RETURN
			    DIVIDE(_ADC, 17)
		formatString: 0.0%
		displayFolder: Utilization
		lineageTag: c7c320e8-5d3c-493d-913e-19a2bd5745ed


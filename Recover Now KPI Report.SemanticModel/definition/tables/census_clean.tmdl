	/// Returns the most recent week_ending date in the census data as a formatted string for display in a card visual.
	measure 'Report As Of' = FORMAT(MAX('census_clean'[week_ending]), "M/D/YY")
		formatString: @
		displayFolder: KPIs
		lineageTag: 2bf3cb4a-81a4-4f73-9e40-a0a829ad9f59

	/// Budgeted ADC for EDTC. Uses dim_month[month] as context so future months show even without census data.
	measure 'Budget ADC - EDTC' =
			VAR _Month = SELECTEDVALUE('dim_month'[month])
			RETURN
			    IF(
			        NOT ISBLANK(_Month),
			        CALCULATE(
			            SUM('budget'[budget_adc]),
			            'budget'[budget_category] = "EDTC",
			            'budget'[month] = _Month
			        )
			    )
		formatString: #,##0.0
		displayFolder: Targets
		lineageTag: a73e2e64-d3c3-4ec7-9955-963ad45319f9


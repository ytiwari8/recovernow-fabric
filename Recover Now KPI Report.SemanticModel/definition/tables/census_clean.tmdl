				    Source = Sql.Databases("ljnbfyiwxwkuji25h72yz4rawu-z7vxf66mtbredbojluqefofxsu.datawarehouse.fabric.microsoft.com"),
				    kipu_lakehouse = Source{[Name="kipu_lakehouse"]}[Data],
				    dbo_census_clean = kipu_lakehouse{[Schema="dbo",Item="census_clean"]}[Data]
				in

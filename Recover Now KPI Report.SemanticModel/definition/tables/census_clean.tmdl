	/// Weekly admits: distinct casefiles whose first census date (MIN census_date) falls within the current week_ending context. Uses MIN census_date instead of admission_date = census_date to handle facilities where the first census row is recorded the day after admission.
	measure Admits =
			VAR _WeekEnd = SELECTEDVALUE('census_clean'[week_ending])
			VAR _WeekStart = _WeekEnd - 6
			RETURN
			    IF(
			        NOT ISBLANK(_WeekEnd),
			        CALCULATE(
			            DISTINCTCOUNT('census_clean'[casefile_id]),
			            FILTER(
			                SUMMARIZE(
			                    ALL('census_clean'),
			                    'census_clean'[casefile_id],
			                    "_FirstCensus", MIN('census_clean'[census_date])
			                ),
			                [_FirstCensus] >= _WeekStart && [_FirstCensus] <= _WeekEnd
			            )
			        ),
			        CALCULATE(
			            DISTINCTCOUNT('census_clean'[casefile_id]),
			            'census_clean'[census_date] = 'census_clean'[admission_date]
			        )
			    )
		formatString: #,##0
		displayFolder: KPIs
		lineageTag: 790d4fb3-eb6d-488f-bc09-b0e26851080a

	/// Count of distinct discharged casefiles (rows with a discharge date) in context. Used as denominator for ALOS and AMA Rate.
	measure Discharges =
			CALCULATE(
			    DISTINCTCOUNT('census_clean'[casefile_id]),
			    NOT(ISBLANK('census_clean'[discharge_date]))
			)
		formatString: #,##0
		displayFolder: KPIs
		lineageTag: ba5baf64-8fa7-4d1a-8f29-12ae529076cd

	/// Count of distinct casefiles discharged AMA (discharge_group = AMA).
	measure 'AMA Discharges' =
			CALCULATE(
			    DISTINCTCOUNT('census_clean'[casefile_id]),
			    'census_clean'[discharge_group] = "AMA"
			)
		formatString: #,##0
		displayFolder: KPIs
		lineageTag: c0b989a3-ce4b-4318-965f-fb619f524ec5

	/// AMA Rate: AMA discharges / total discharges.
	measure 'AMA Rate' = DIVIDE([AMA Discharges], [Discharges])
		formatString: 0.0%
		displayFolder: KPIs
		lineageTag: d5d88f0d-41d4-4d4d-834f-a58e41c1a802

	/// Average length of stay in days: for each discharged casefile, compute discharge_date - admission_date, then average across distinct casefiles in context.
	measure 'Avg LOS' =
			AVERAGEX(
			    FILTER(
			        SUMMARIZE(
			            'census_clean',
			            'census_clean'[casefile_id],
			            "_admit",  MIN('census_clean'[admission_date]),
			            "_dc",     MIN('census_clean'[discharge_date])
			        ),
			        NOT(ISBLANK([_dc]))
			    ),
			    [_dc] - [_admit]
			)
		formatString: #,##0.0
		displayFolder: KPIs
		lineageTag: 232cceff-c721-4ece-bc00-76833f7e598d


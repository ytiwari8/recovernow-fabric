	/// Variance (Actual minus Budget) for EDTC ADC. Positive = above budget.
	measure 'Variance ADC - EDTC' =
			VAR _Actual = [Actual ADC - EDTC]
			VAR _Budget = [Budget ADC - EDTC]
			RETURN IF(NOT ISBLANK(_Actual) && NOT ISBLANK(_Budget), _Actual - _Budget)
		formatString: #,##0.0;-#,##0.0
		displayFolder: Budget vs Actual
		lineageTag: 43ebcfb9-9555-41f4-bddf-06fc0542b66c

	/// Variance (Actual minus Budget) for NORA ADC. Positive = above budget.
	measure 'Variance ADC - NORA' =
			VAR _Actual = [Actual ADC - NORA]
			VAR _Budget = [Budget ADC - NORA]
			RETURN IF(NOT ISBLANK(_Actual) && NOT ISBLANK(_Budget), _Actual - _Budget)
		formatString: #,##0.0;-#,##0.0
		displayFolder: Budget vs Actual
		lineageTag: 069cd3d6-a5e3-4e7e-b92f-201ca6bc968f

	/// Variance % (Actual vs Budget) for EDTC. Positive = above budget.
	measure 'Variance % - EDTC' = DIVIDE([Actual ADC - EDTC] - [Budget ADC - EDTC], [Budget ADC - EDTC])
		formatString: +0.0%;-0.0%
		displayFolder: Budget vs Actual
		lineageTag: bbecaae7-3aca-40bd-9d9b-126eb0fd80ef

